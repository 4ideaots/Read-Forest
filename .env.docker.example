# docker compose 용 환경변수. 서버에서 `cp .env.docker.example .env` 후 채우세요.
# (compose 가 같은 폴더의 .env 를 자동으로 읽어 ${...} 를 치환합니다)

# --- 도메인 / 인증서 (certbot) ---
# ▶ DOMAIN 이 도메인 단일 소스입니다. 이 값 하나만 바꾸면
#   nginx server_name · SSL 인증서 경로 · certbot 발급 · OAuth2 콜백이 모두 따라갑니다.
# Let's Encrypt 는 IP 가 아닌 도메인이 필요합니다. A 레코드가 EC2 IP 를 가리켜야 합니다.
DOMAIN=read-forest.example.com
CERTBOT_EMAIL=you@example.com
CERTBOT_STAGING=0          # 처음 테스트할 땐 1 로 두면 rate limit 안전, 성공 확인 후 0

# --- Database (AWS RDS / MySQL) ---
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_NAME=readforest
DB_USERNAME=admin
DB_PASSWORD=change-me

# --- Kakao Book Search API (책 검색에 필수) ---
KAKAO_API_KEY=your-kakao-rest-api-key

# --- OAuth2 (선택) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# 비워두면 https://${DOMAIN}/oauth2/callback 로 자동 설정됨
OAUTH2_REDIRECT_URI=

# --- JWT ---
# ⚠️ 반드시 `openssl rand -base64 48` 로 생성한 "표준 Base64" 값을 넣으세요.
#    하이픈(-)이나 밑줄(_)이 들어가면 디코딩 에러(Illegal base64 character)로 백엔드가 죽습니다.
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_48
