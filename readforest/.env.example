# Configuration Template (Copy this to .env and fill in your values)

# --- Database (MySQL / AWS RDS) ---
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_NAME=readforest
DB_USERNAME=admin
DB_PASSWORD=your_password

# --- Kakao Book Search API (REQUIRED for book search) ---
# 카카오 디벨로퍼스 > 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_API_KEY=your-kakao-rest-api-key

# --- Kakao OAuth2 Login (optional; only if you enable Kakao social login) ---
# CLIENT_ID = REST API 키와 동일, CLIENT_SECRET = 보안 > Client Secret
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# --- GitHub OAuth2 Login (optional) ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth2 success redirect (frontend)
OAUTH2_REDIRECT_URI=http://localhost:5173/oauth2/callback

# JWT secret (Base64). Leave default for local dev or set your own.
# JWT_SECRET=...
